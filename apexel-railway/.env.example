PORT=3000
JWT_SECRET=your_random_secret_here

# Telegram Bot
BOT_TOKEN=123456:ABCdef...
API_SECRET=your_bot_api_secret
BOT_USERNAME=YourBotName

# Paths (Railway sets these automatically)
# RAILWAY_VOLUME_MOUNT_PATH=/data
